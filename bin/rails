#!/usr/bin/env ruby
# Delegates all rails commands to the dummy app so `bin/rails server` etc. work
# from the engine root without needing to cd into spec/dummy.

ENGINE_ROOT = File.expand_path("..", __dir__)
ENGINE_PATH = File.expand_path("../lib/rails_audit_log/engine", __dir__)
APP_PATH    = File.expand_path("../spec/dummy/config/application", __dir__)

ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)
require "bundler/setup" if File.exist?(ENV["BUNDLE_GEMFILE"])

require "rails/all"
require "rails/commands"
