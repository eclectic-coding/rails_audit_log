<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>RailsAuditLog — Dev Sandbox</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; font-size: 14px; color: #1a1a1a; background: #f5f5f5; }
      header { background: #1a1a1a; color: #fff; padding: 12px 24px; display: flex; align-items: center; gap: 12px; }
      header h1 { font-size: 16px; font-weight: 600; }
      header span { font-size: 12px; color: #888; }
      main { padding: 24px; max-width: 1200px; margin: 0 auto; }
    </style>
  </head>
  <body>
    <header>
      <h1>RailsAuditLog</h1>
      <span>dev sandbox</span>
    </header>
    <main><%= yield %></main>
  </body>
</html>