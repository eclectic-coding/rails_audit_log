<style>
  .page-header { margin-bottom: 20px; }
  .page-header h2 { font-size: 20px; font-weight: 600; }
  .page-header p  { color: #666; margin-top: 4px; }
  .stats { display: flex; gap: 12px; margin-bottom: 20px; }
  .stat { background: #fff; border: 1px solid #e5e5e5; border-radius: 6px; padding: 12px 16px; min-width: 100px; }
  .stat-value { font-size: 24px; font-weight: 700; }
  .stat-label { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }
  table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e5e5e5; border-radius: 6px; overflow: hidden; }
  th { background: #f9f9f9; text-align: left; padding: 10px 14px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #666; border-bottom: 1px solid #e5e5e5; }
  td { padding: 10px 14px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
  tr:last-child td { border-bottom: none; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
  .badge-create  { background: #dcfce7; color: #166534; }
  .badge-update  { background: #dbeafe; color: #1e40af; }
  .badge-destroy { background: #fee2e2; color: #991b1b; }
  .attrs { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 6px; }
  .attr-tag { background: #f3f4f6; border-radius: 4px; padding: 1px 6px; font-size: 11px; font-family: monospace; color: #374151; }
  .diff-row { font-size: 12px; font-family: monospace; margin-bottom: 3px; }
  .diff-from { color: #991b1b; text-decoration: line-through; margin-right: 6px; }
  .diff-to   { color: #166534; }
  .muted { color: #aaa; font-style: italic; }
  .snapshot-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #a3e635; title: "snapshot stored"; }
  .reify-box { margin-top: 6px; padding: 4px 8px; background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 4px; font-size: 11px; font-family: monospace; color: #0369a1; }
  .nav-links { font-size: 11px; color: #888; margin-top: 4px; }
</style>

<div class="page-header">
  <h2>Audit Log Entries</h2>
  <p>Last 50 entries, newest first</p>
</div>

<div class="stats">
  <div class="stat">
    <div class="stat-value"><%= RailsAuditLog::AuditLogEntry.count %></div>
    <div class="stat-label">Total</div>
  </div>
  <div class="stat">
    <div class="stat-value"><%= RailsAuditLog::AuditLogEntry.created_events.count %></div>
    <div class="stat-label">Creates</div>
  </div>
  <div class="stat">
    <div class="stat-value"><%= RailsAuditLog::AuditLogEntry.updated_events.count %></div>
    <div class="stat-label">Updates</div>
  </div>
  <div class="stat">
    <div class="stat-value"><%= RailsAuditLog::AuditLogEntry.destroyed_events.count %></div>
    <div class="stat-label">Destroys</div>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th>Event</th>
      <th>Item</th>
      <th>Actor</th>
      <th>Diff</th>
      <th>Reify (pre-change state)</th>
      <th>Nav</th>
      <th>When</th>
    </tr>
  </thead>
  <tbody>
    <% @entries.each do |entry| %>
      <tr>
        <td>
          <span class="badge badge-<%= entry.event %>"><%= entry.event %></span>
          <% if entry.object.present? %>
            <span class="snapshot-dot" title="full snapshot stored"></span>
          <% end %>
        </td>
        <td><%= entry.item_type %> #<%= entry.item_id %></td>
        <td>
          <% if entry.actor %>
            <%= entry.actor_type %> #<%= entry.actor_id %>
          <% else %>
            <span class="muted">anonymous</span>
          <% end %>
        </td>
        <td>
          <% if entry.changed_attributes.any? %>
            <div class="attrs">
              <% entry.changed_attributes.each do |attr| %>
                <span class="attr-tag"><%= attr %></span>
              <% end %>
            </div>
            <% entry.diff.each do |attr, change| %>
              <div class="diff-row">
                <span class="diff-from"><%= change[:from].inspect %></span>
                <span class="diff-to"><%= change[:to].inspect %></span>
              </div>
            <% end %>
          <% else %>
            <span class="muted">—</span>
          <% end %>
        </td>
        <td>
          <% prior = entry.reify %>
          <% if prior %>
            <div class="reify-box">
              <% prior.attributes.except("id", "created_at", "updated_at").each do |k, v| %>
                <div><%= k %>: <%= v.inspect %></div>
              <% end %>
            </div>
          <% else %>
            <span class="muted">—</span>
          <% end %>
        </td>
        <td class="nav-links">
          <% if entry.previous %>← #<%= entry.previous.id %><% end %>
          <% if entry.previous && entry.next %> · <% end %>
          <% if entry.next %>#<%= entry.next.id %> →<% end %>
          <% unless entry.previous || entry.next %><span class="muted">—</span><% end %>
        </td>
        <td><%= entry.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
      </tr>
    <% end %>
  </tbody>
</table>